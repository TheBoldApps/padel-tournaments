{
  "expo": {
    "icon": "https://agent.expo.app/static/icon.png",
    "orientation": "default",
    "scheme": "acme",
    "userInterfaceStyle": "automatic",
    "web": {
      "output": "server"
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "expo-font",
      "expo-image",
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "18.5"
          },
          "android": {
            "minSdkVersion": 28,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      "expo-apple-authentication"
    ],
    "name": "Padel HQ",
    "slug": "tournament-pedal-organizer",
    "owner": "theboldapps",
    "ios": {
      "bundleIdentifier": "com.padel.americano.mexicano.tournament",
      "usesAppleSignIn": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee686892-524b-475d-aa74-e813aebbc046"
      }
    }
  }
}
